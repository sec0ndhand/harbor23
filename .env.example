# Public site URL — used for sitemap and canonical URLs.
# On Netlify deploy previews, leave unset; Netlify auto-injects URL per-deploy.
SITE_URL=https://harbor23.com

# Google Analytics 4 measurement ID (G-XXXXXXXXXX). Optional: if unset, the
# gtag snippet is not emitted, which is what you want in local dev.
GA4_MEASUREMENT_ID=
